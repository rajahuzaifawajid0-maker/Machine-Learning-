<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Supermarket Sales — Receipt Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  :root{
    --paper:#FDF6F0;
    --paper-2:#FCEAE4;
    --ink:#3A2E2A;
    --ink-soft:#8A7A72;
    --green:#3E9C7A;
    --green-light:#E3F5EC;
    --red:#E8637A;
    --amber:#F0A93E;
    --pink:#F492A6;
    --lav:#A88CD8;
    --blue:#5FA8D3;
    --gray:#C7B8AE;
    --line: rgba(58,46,42,0.14);
    --font-mono:'Space Mono', monospace;
    --font-sans:'IBM Plex Sans', sans-serif;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    background:#F1D9CE;
    font-family:var(--font-sans);
    color:var(--ink);
    padding:32px 16px 64px;
    display:flex;
    justify-content:center;
  }
  .receipt{
    width:100%;
    max-width:900px;
    background:var(--paper);
    position:relative;
    padding:0 0 40px;
    border-radius:18px;
    overflow:hidden;
    box-shadow:0 16px 44px rgba(196,120,110,0.28);
  }
  .tear-top, .tear-bottom{
    height:14px;
    width:100%;
    background:
      linear-gradient(135deg, var(--paper) 25%, transparent 25%) 0 0,
      linear-gradient(225deg, var(--paper) 25%, transparent 25%) 0 0;
    background-size:16px 16px;
    background-color:#F1D9CE;
  }
  .tear-bottom{ transform: rotate(180deg); }
  .head{
    text-align:center;
    padding:28px 24px 18px;
    border-bottom:1px dashed var(--line);
  }
  .head .store{
    font-family:var(--font-mono);
    font-weight:700;
    font-size:22px;
    letter-spacing:2px;
    margin:0;
  }
  .head .sub{
    font-family:var(--font-mono);
    font-size:11px;
    color:var(--ink-soft);
    margin:6px 0 0;
    letter-spacing:1px;
  }
  .head .divider-dots{
    margin-top:14px;
    font-size:12px;
    color:var(--pink);
    letter-spacing:3px;
  }

  .filters{
    display:flex;
    flex-wrap:wrap;
    gap:10px;
    padding:18px 24px;
    border-bottom:1px dashed var(--line);
    align-items:center;
  }
  .filters .flabel{
    font-family:var(--font-mono);
    font-size:11px;
    color:var(--ink-soft);
    letter-spacing:1px;
    margin-right:2px;
  }
  select{
    font-family:var(--font-mono);
    font-size:12px;
    padding:7px 10px;
    background:var(--paper-2);
    border:1px solid var(--line);
    border-radius:8px;
    color:var(--ink);
  }
  select:focus{ outline:2px solid var(--green); outline-offset:1px; }
  .reset-btn{
    font-family:var(--font-mono);
    font-size:11px;
    letter-spacing:1px;
    background:none;
    border:1px solid var(--pink);
    color:var(--red);
    padding:7px 12px;
    border-radius:8px;
    cursor:pointer;
  }
  .reset-btn:hover{ background:#FDECEF; border-color:var(--red); color:var(--red); }

  .kpi-strip{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    border-bottom:1px dashed var(--line);
    gap:1px;
    background:var(--line);
  }
  .kpi{
    padding:18px 14px;
    text-align:center;
    background:var(--paper);
  }
  .kpi:nth-child(1){ background:#EAF7F0; }
  .kpi:nth-child(2){ background:#FDECEF; }
  .kpi:nth-child(3){ background:#FCF2E1; }
  .kpi:nth-child(4){ background:#F1EBFA; }
  .kpi .k-label{
    font-family:var(--font-mono);
    font-size:10px;
    letter-spacing:1px;
    color:var(--ink-soft);
    text-transform:uppercase;
  }
  .kpi .k-value{
    font-family:var(--font-mono);
    font-weight:700;
    font-size:20px;
    margin-top:6px;
    color:var(--ink);
  }

  .line-item{
    padding:22px 24px;
    border-bottom:1px dashed var(--line);
    border-left:5px solid transparent;
  }
  .line-item:nth-of-type(1){ background:#EAF7F0; border-left-color:var(--green); }
  .line-item:nth-of-type(2){ background:#FDECEF; border-left-color:var(--red); }
  .line-item:nth-of-type(3){ background:#FCF2E1; border-left-color:var(--amber); }
  .line-item:nth-of-type(4){ background:#F1EBFA; border-left-color:var(--lav); }
  .line-item:nth-of-type(5){ background:#EAF3FA; border-left-color:var(--blue); }
  .line-item:nth-of-type(6){ background:#FDF0E6; border-left-color:#F4B860; }
  .li-head{
    display:flex;
    justify-content:space-between;
    align-items:baseline;
    margin-bottom:14px;
  }
  .li-title{
    font-family:var(--font-mono);
    font-weight:700;
    font-size:13px;
    letter-spacing:0.5px;
  }
  .li-no{
    font-family:var(--font-mono);
    font-size:11px;
    color:var(--gray);
  }
  .chart-wrap{ position:relative; width:100%; }

  .legend-row{
    display:flex;
    flex-wrap:wrap;
    gap:12px;
    margin-bottom:10px;
    font-family:var(--font-mono);
    font-size:11px;
    color:var(--ink-soft);
  }
  .legend-row span.sw{
    display:inline-block;
    width:9px;height:9px;
    margin-right:5px;
    vertical-align:-1px;
  }

  .total-block{
    padding:26px 24px 6px;
    text-align:right;
  }
  .total-block .t-label{
    font-family:var(--font-mono);
    font-size:12px;
    color:var(--ink-soft);
    letter-spacing:1px;
  }
  .total-block .t-value{
    font-family:var(--font-mono);
    font-weight:700;
    font-size:28px;
    margin-top:4px;
  }
  .barcode-wrap{
    display:flex;
    justify-content:center;
    padding:20px 24px 6px;
  }
  .footer-note{
    text-align:center;
    font-family:var(--font-mono);
    font-size:10px;
    color:var(--gray);
    letter-spacing:1px;
    padding-top:8px;
  }

  @media (max-width:640px){
    .kpi-strip{ grid-template-columns:repeat(2,1fr); }
    .kpi:nth-child(2){ border-right:none; }
    .line-item.split{ grid-template-columns:1fr; }
    .line-item.split > div:first-child{ border-right:none; border-bottom:1px dashed var(--line); }
  }
</style>
</head>
<body>
<div class="receipt">
  <div class="tear-top"></div>

  <div class="head">
    <p class="store">SUPERMART CO.</p>
    <p class="sub">SALES ANALYSIS RECEIPT — YANGON · NAYPYITAW · MANDALAY</p>
    <div class="divider-dots">· · · · · · · · · · · · · · · · · ·</div>
  </div>

  <div class="filters">
    <span class="flabel">FILTER:</span>
    <select id="fBranch"><option value="all">All branches</option></select>
    <select id="fMonth"><option value="all">All months</option></select>
    <select id="fProduct"><option value="all">All product lines</option></select>
    <button class="reset-btn" id="resetBtn">CLEAR</button>
  </div>

  <div class="kpi-strip">
    <div class="kpi"><div class="k-label">Total revenue</div><div class="k-value" id="kpiRevenue">$0</div></div>
    <div class="kpi"><div class="k-label">Transactions</div><div class="k-value" id="kpiCount">0</div></div>
    <div class="kpi"><div class="k-label">Avg basket</div><div class="k-value" id="kpiBasket">$0</div></div>
    <div class="kpi"><div class="k-label">Avg rating</div><div class="k-value" id="kpiRating">0.0</div></div>
  </div>

  <div class="line-item">
    <div class="li-head"><span class="li-title">01 — MONTHLY REVENUE</span><span class="li-no">LINE CHART</span></div>
    <div class="chart-wrap" style="height:260px;">
      <canvas id="chartMonthly" role="img" aria-label="Line chart of monthly revenue">Monthly revenue trend across the filtered period.</canvas>
    </div>
  </div>

  <div class="line-item">
    <div class="li-head"><span class="li-title">02 — REVENUE BY PRODUCT LINE</span><span class="li-no">BAR</span></div>
    <div class="chart-wrap" style="height:260px;">
      <canvas id="chartProduct" role="img" aria-label="Bar chart of revenue by product line">Revenue broken down by product line.</canvas>
    </div>
  </div>

  <div class="line-item">
    <div class="li-head"><span class="li-title">03 — PAYMENT METHOD SHARE</span><span class="li-no">DONUT</span></div>
    <div class="legend-row" id="legendPayment"></div>
    <div class="chart-wrap" style="height:260px;">
      <canvas id="chartPayment" role="img" aria-label="Donut chart of payment method share">Share of transactions by payment method.</canvas>
    </div>
  </div>

  <div class="line-item">
    <div class="li-head"><span class="li-title">04 — CUSTOMER TYPE</span><span class="li-no">BAR</span></div>
    <div class="chart-wrap" style="height:260px;">
      <canvas id="chartCustomer" role="img" aria-label="Bar chart of customer type distribution">Count of transactions by customer type.</canvas>
    </div>
  </div>

  <div class="line-item">
    <div class="li-head"><span class="li-title">05 — QUANTITY DISTRIBUTION</span><span class="li-no">HISTOGRAM</span></div>
    <div class="chart-wrap" style="height:260px;">
      <canvas id="chartQtyHist" role="img" aria-label="Histogram of items purchased per transaction">Distribution of quantity purchased per transaction.</canvas>
    </div>
  </div>

  <div class="line-item">
    <div class="li-head"><span class="li-title">06 — QUANTITY VS REVENUE</span><span class="li-no">SCATTER</span></div>
    <div class="chart-wrap" style="height:260px;">
      <canvas id="chartScatter" role="img" aria-label="Scatter plot of quantity versus revenue per transaction">Each point is one transaction, quantity against revenue.</canvas>
    </div>
  </div>

  <div class="total-block">
    <div class="t-label">GRAND TOTAL (FILTERED)</div>
    <div class="t-value" id="grandTotal">$0.00</div>
  </div>
  <div class="barcode-wrap"><svg id="barcodeSvg" height="46"></svg></div>
  <div class="footer-note">THANK YOU FOR SHOPPING — DATA COVERS JAN–MAR 2019</div>

  <div class="tear-bottom"></div>
</div>

