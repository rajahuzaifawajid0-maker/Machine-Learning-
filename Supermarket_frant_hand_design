<script>
const RAW = JSON.parse(document.getElementById('raw-data').textContent);

const MONTH_ORDER = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const GREEN = '#3E9C7A';
const RED = '#E8637A';
const AMBER = '#F0A93E';
const GRAY = '#C7B8AE';
const BLUE = '#5FA8D3';
const LAV = '#A88CD8';
const SERIES = [GREEN, RED, AMBER, BLUE, LAV, '#F4B860'];

function uniqSorted(arr){ return [...new Set(arr)].sort(); }

const branches = uniqSorted(RAW.map(r=>r.branch));
const months = MONTH_ORDER.filter(m => RAW.some(r=>r.month===m));
const products = uniqSorted(RAW.map(r=>r.productLine));

function fillSelect(id, values, prefixAll){
  const sel = document.getElementById(id);
  values.forEach(v=>{
    const opt = document.createElement('option');
    opt.value = v; opt.textContent = v;
    sel.appendChild(opt);
  });
}
fillSelect('fBranch', branches);
fillSelect('fMonth', months);
fillSelect('fProduct', products);

const fmt$ = (v) => '$' + Number(v).toLocaleString(undefined,{maximumFractionDigits:0});
const fmt$2 = (v) => '$' + Number(v).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2});

let charts = {};
function destroyCharts(){ Object.values(charts).forEach(c=>c && c.destroy()); charts = {}; }

const commonGrid = { color:'#e1e0d9', drawTicks:false };
const commonTicks = { color:'#898781', font:{ family:'Space Mono', size:10 } };

function getFiltered(){
  const b = document.getElementById('fBranch').value;
  const m = document.getElementById('fMonth').value;
  const p = document.getElementById('fProduct').value;
  return RAW.filter(r =>
    (b==='all' || r.branch===b) &&
    (m==='all' || r.month===m) &&
    (p==='all' || r.productLine===p)
  );
}

function render(){
  const data = getFiltered();
  destroyCharts();

  const totalRevenue = data.reduce((s,r)=>s+r.total,0);
  const count = data.length;
  const avgBasket = count ? totalRevenue/count : 0;
  const avgRating = count ? data.reduce((s,r)=>s+r.rating,0)/count : 0;

  document.getElementById('kpiRevenue').textContent = fmt$(totalRevenue);
  document.getElementById('kpiCount').textContent = count.toLocaleString();
  document.getElementById('kpiBasket').textContent = fmt$(avgBasket);
  document.getElementById('kpiRating').textContent = avgRating.toFixed(1);
  document.getElementById('grandTotal').textContent = fmt$2(totalRevenue);

  const monthlyMap = {};
  months.forEach(m=>monthlyMap[m]=0);
  data.forEach(r=>{ monthlyMap[r.month] = (monthlyMap[r.month]||0) + r.total; });
  const monthLabels = months.filter(m => document.getElementById('fMonth').value==='all' || m===document.getElementById('fMonth').value);
  charts.monthly = new Chart(document.getElementById('chartMonthly'), {
    type:'line',
    data:{
      labels: monthLabels,
      datasets:[{
        data: monthLabels.map(m=>monthlyMap[m]),
        borderColor: GREEN,
        backgroundColor: 'rgba(62,156,122,0.14)',
        borderWidth:2,
        pointRadius:5,
        pointBackgroundColor: GREEN,
        pointBorderColor:'#FDF6F0',
        pointBorderWidth:2,
        fill:true,
        tension:0.15
      }]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{display:false}, tooltip:{ callbacks:{ label: (ctx)=> fmt$(ctx.raw) } } },
      scales:{
        y:{ grid:commonGrid, ticks:{...commonTicks, callback:(v)=>fmt$(v)} },
        x:{ grid:{display:false}, ticks:commonTicks }
      }
    }
  });

  const prodMap = {};
  products.forEach(p=>prodMap[p]=0);
  data.forEach(r=>{ prodMap[r.productLine] = (prodMap[r.productLine]||0) + r.total; });
  charts.product = new Chart(document.getElementById('chartProduct'), {
    type:'bar',
    data:{
      labels: products.map(p=>p.replace(' and ',' & ')),
      datasets:[{
        data: products.map(p=>prodMap[p]),
        backgroundColor: products.map((_,i)=>SERIES[i%SERIES.length]),
        borderRadius:6,
        maxBarThickness:28
      }]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{display:false}, tooltip:{ callbacks:{ label:(ctx)=>fmt$(ctx.raw) } } },
      scales:{
        y:{ grid:commonGrid, ticks:{...commonTicks, callback:(v)=>fmt$(v)} },
        x:{ grid:{display:false}, ticks:{...commonTicks, maxRotation:45, autoSkip:false, font:{family:'IBM Plex Sans', size:10}} }
      }
    }
  });

  const payMap = {};
  data.forEach(r=>{ payMap[r.payment] = (payMap[r.payment]||0)+1; });
  const payLabels = Object.keys(payMap);
  const payTotal = payLabels.reduce((s,k)=>s+payMap[k],0) || 1;
  const legendEl = document.getElementById('legendPayment');
  legendEl.innerHTML = payLabels.map((k,i)=>{
    const pct = ((payMap[k]/payTotal)*100).toFixed(0);
    return `<span><span class="sw" style="background:${SERIES[i%SERIES.length]}"></span>${k} ${pct}%</span>`;
  }).join('');
  charts.payment = new Chart(document.getElementById('chartPayment'), {
    type:'doughnut',
    data:{
      labels: payLabels,
      datasets:[{
        data: payLabels.map(k=>payMap[k]),
        backgroundColor: payLabels.map((_,i)=>SERIES[i%SERIES.length]),
        borderColor:'#FDF6F0',
        borderWidth:3
      }]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{display:false}, tooltip:{ callbacks:{ label:(ctx)=>ctx.label+': '+ctx.raw } } }
    }
  });

  const custMap = {};
  data.forEach(r=>{ custMap[r.custType] = (custMap[r.custType]||0)+1; });
  const custLabels = Object.keys(custMap);
  charts.customer = new Chart(document.getElementById('chartCustomer'), {
    type:'bar',
    data:{
      labels: custLabels,
      datasets:[{
        data: custLabels.map(k=>custMap[k]),
        backgroundColor: [LAV, AMBER],
        borderRadius:6,
        maxBarThickness:60
      }]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{display:false}, tooltip:{ callbacks:{ label:(ctx)=>ctx.raw+' transactions' } } },
      scales:{
        y:{ grid:commonGrid, ticks:commonTicks },
        x:{ grid:{display:false}, ticks:{...commonTicks, font:{family:'IBM Plex Sans', size:11}} }
      }
    }
  });

  const qtyVals = data.map(r=>r.quantity);
  const bins = Array.from({length:10}, (_,i)=>i+1);
  const qtyCounts = bins.map(b => qtyVals.filter(q=>q===b).length);
  charts.qtyHist = new Chart(document.getElementById('chartQtyHist'), {
    type:'bar',
    data:{
      labels: bins,
      datasets:[{
        data: qtyCounts,
        backgroundColor: '#F492A6',
        borderRadius:5,
        categoryPercentage:1.0,
        barPercentage:0.92
      }]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{display:false}, tooltip:{ callbacks:{ label:(ctx)=>ctx.raw+' transactions' } } },
      scales:{
        y:{ grid:commonGrid, ticks:commonTicks, title:{display:true, text:'Frequency', color:'#898781', font:{family:'Space Mono', size:10}} },
        x:{ grid:{display:false}, ticks:commonTicks, title:{display:true, text:'Items per transaction', color:'#898781', font:{family:'Space Mono', size:10}} }
      }
    }
  });

  charts.scatter = new Chart(document.getElementById('chartScatter'), {
    type:'scatter',
    data:{
      datasets:[{
        data: data.map(r=>({x:r.quantity, y:r.total})),
        backgroundColor: 'rgba(95,168,211,0.6)',
        pointRadius:4,
        pointStyle:'circle'
      }]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      layout:{ padding:10 },
      plugins:{ legend:{display:false}, tooltip:{ callbacks:{ label:(ctx)=>`qty ${ctx.raw.x}, ${fmt$(ctx.raw.y)}` } } },
      scales:{
        y:{ grid:commonGrid, ticks:{...commonTicks, callback:(v)=>fmt$(v)}, title:{display:true, text:'Revenue', color:'#898781', font:{family:'Space Mono', size:10}} },
        x:{ grid:commonGrid, ticks:commonTicks, min:0, max:11, title:{display:true, text:'Quantity', color:'#898781', font:{family:'Space Mono', size:10}} }
      }
    }
  });

  drawBarcode(count);
}

function drawBarcode(seed){
  const svg = document.getElementById('barcodeSvg');
  svg.innerHTML = '';
  svg.setAttribute('width', '220');
  const bars = 40;
  let x = 0;
  const rnd = mulberry32(seed || 1);
  for(let i=0;i<bars;i++){
    const w = rnd() > 0.6 ? 3 : 1.5;
    if(rnd() > 0.35){
      const r = document.createElementNS('http://www.w3.org/2000/svg','rect');
      r.setAttribute('x', x);
      r.setAttribute('y', 0);
      r.setAttribute('width', w);
      r.setAttribute('height', 40);
      r.setAttribute('fill', '#1A1A1A');
      svg.appendChild(r);
    }
    x += w + 2;
  }
  svg.setAttribute('viewBox', `0 0 ${x} 46`);
}
function mulberry32(a){
  return function(){
    a |= 0; a = a + 0x6D2B79F5 | 0;
    let t = Math.imul(a ^ a >>> 15, 1 | a);
    t = t + Math.imul(t ^ t >>> 7, 61 | t) ^ t;
    return ((t ^ t >>> 14) >>> 0) / 4294967296;
  }
}

['fBranch','fMonth','fProduct'].forEach(id=>{
  document.getElementById(id).addEventListener('change', render);
});
document.getElementById('resetBtn').addEventListener('click', ()=>{
  document.getElementById('fBranch').value = 'all';
  document.getElementById('fMonth').value = 'all';
  document.getElementById('fProduct').value = 'all';
  render();
});

render();
</script>
